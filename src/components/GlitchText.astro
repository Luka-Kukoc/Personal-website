---
/**
 * Glitch text effect (medium intensity). Renders the text with two offset
 * red/cyan copies that jitter on hover. Disabled if theme.effects.glitch=false.
 *
 * Usage: <GlitchText text="HELLO" as="h1" />
 */
import { theme } from '../config/theme';

interface Props {
  text: string;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}
const { text, as: Tag = 'span', class: className = '' } = Astro.props;
const enabled = theme.effects.glitch;
---

<Tag
  class:list={['glitch', className, { 'glitch--on': enabled }]}
  data-text={text}
>
  {text}
</Tag>

<style>
  .glitch {
    position: relative;
    display: inline-block;
    color: var(--color-text);
  }

  .glitch--on::before,
  .glitch--on::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.85;
    clip-path: inset(0 0 0 0);
  }

  .glitch--on::before {
    color: var(--color-primary);
    transform: translate(-2px, 0);
    mix-blend-mode: screen;
  }
  .glitch--on::after {
    color: var(--color-secondary);
    transform: translate(2px, 0);
    mix-blend-mode: screen;
  }

  .glitch--on:hover::before {
    animation: glitch-x 0.35s steps(2, end) infinite;
  }
  .glitch--on:hover::after {
    animation: glitch-y 0.35s steps(2, end) infinite reverse;
  }

  @keyframes glitch-x {
    0%   { clip-path: inset(0 0 70% 0); transform: translate(-3px, -1px); }
    50%  { clip-path: inset(40% 0 20% 0); transform: translate(3px, 1px); }
    100% { clip-path: inset(70% 0 0 0); transform: translate(-2px, 0); }
  }
  @keyframes glitch-y {
    0%   { clip-path: inset(60% 0 10% 0); transform: translate(3px, 1px); }
    50%  { clip-path: inset(10% 0 60% 0); transform: translate(-3px, -1px); }
    100% { clip-path: inset(30% 0 30% 0); transform: translate(2px, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch--on::before,
    .glitch--on::after { display: none; }
  }
</style>
